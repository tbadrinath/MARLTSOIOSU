{
  "name": "iutms-server",
  "version": "1.0.0",
  "description": "Real-time telemetry server for the Intelligent Urban Traffic Management System (IUTMS)",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "demo": "DEMO=true node server.js",
    "build:exe": "npx --yes pkg . --targets node18-win-x64 --output ../../dist/windows/release/IUTMS-Server.exe"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "socket.io": "^4.6.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pkg": {
    "assets": [
      "../client/build/**/*"
    ]
  },
  "license": "MIT"
}
