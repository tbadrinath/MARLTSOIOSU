# URL of the IUTMS telemetry server (Express + Socket.io backend).
# When deploying to Vercel without a separate backend, leave this unset
# and use Demo Mode in the dashboard to explore the UI with simulated data.
#
# Example (local development):
#   REACT_APP_SERVER_URL=http://localhost:3001
#
# Example (self-hosted backend):
#   REACT_APP_SERVER_URL=https://iutms-server.example.com

REACT_APP_SERVER_URL=http://localhost:3001
